generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum LeadPriority {
  HOT
  WARM
  COLD
}

enum LeadStatus {
  NOT_CONTACTED
  CONTACTED
  REPLIED
  CLOSED
  ARCHIVED
}

enum PipelineStage {
  NOT_CONTACTED
  DRAFTED
  SENT
  REPLIED
  MEETING
  PROPOSAL
  WON
  LOST
}

enum WebsiteStatus {
  WORKING
  CLOUDFLARE
  CAPTCHA
  FORBIDDEN
  NOT_FOUND
  SERVER_ERROR
  SSL_ERROR
  TIMEOUT
  REDIRECT_LOOP
  DOMAIN_PARKED
  WEBSITE_OFFLINE
  NO_WEBSITE
  BOT_PROTECTION
  UNKNOWN
}

enum ScanJobStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum ScanDepth {
  QUICK
  FULL
  DEEP
}

enum ScreenshotType {
  DESKTOP
  MOBILE
}

enum OutreachType {
  EMAIL
  LINKEDIN_DM
  FOLLOW_UP_1
  FOLLOW_UP_2
}

enum OutreachDraftStatus {
  DRAFT
  SAVED
  COPIED
  SENT
  ARCHIVED
}

enum AutomationFrequency {
  DAILY
  WEEKLY
}

enum AutomationNotificationType {
  INFO
  SUCCESS
  ERROR
}

model User {
  id            String              @id @default(cuid())
  name          String
  email         String              @unique
  passwordHash  String
  role          UserRole            @default(ADMIN)
  notes         LeadNote[]
  statusHistory LeadStatusHistory[]
  imports       Import[]
  scanJobs      ScanJob[]
  scanTemplates ScanTemplate[]
  assignedLeads Lead[]              @relation("LeadOwner")
  outreachDrafts OutreachDraft[]
  automationSchedules AutomationSchedule[]
  automationNotifications AutomationNotification[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("users")
}

model Lead {
  id             String              @id @default(cuid())
  company        String
  website        String              @unique
  phone          String?
  address        String?
  industry       String?
  location       String?
  screenshotPath String?
  mobileScreenshotPath String?
  score          Int                 @default(7)
  visualDesignScore Int?
  mobileScore       Int?
  trustScore        Int?
  ctaScore          Int?
  seoScore          Int?
  opportunityScore  Int?
  estimatedProjectValue String?
  priority       LeadPriority        @default(COLD)
  outreachEmail  String?             @db.Text
  status         LeadStatus          @default(NOT_CONTACTED)
  pipelineStage  PipelineStage       @default(NOT_CONTACTED)
  assignedToUserId String?
  assignedTo    User?                @relation("LeadOwner", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  reminderDate  DateTime?
  websiteStatus  WebsiteStatus       @default(UNKNOWN)
  statusCode     Int?
  accessIssue    String?
  accessIssueReason String?          @db.Text
  lastCheckedAt  DateTime?
  recommendedFixes Json?
  issues         LeadIssue[]
  notes          LeadNote[]
  statusHistory  LeadStatusHistory[]
  screenshots    Screenshot[]
  serviceOpportunities ServiceOpportunity[]
  outreachDrafts OutreachDraft[]
  competitors    Competitor[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([company])
  @@index([industry])
  @@index([location])
  @@index([status])
  @@index([pipelineStage])
  @@index([assignedToUserId])
  @@index([reminderDate])
  @@index([priority])
  @@index([websiteStatus])
  @@map("leads")
}

model Industry {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  description String?              @db.Text
  scoringRule IndustryScoringRule?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("industries")
}

model AgencyService {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  description String?              @db.Text
  baseMinValue Int
  baseMaxValue Int
  opportunities ServiceOpportunity[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("services")
}

model IndustryScoringRule {
  id                String   @id @default(cuid())
  industryId        String   @unique
  industry          Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)
  designWeight      Float    @default(1)
  mobileWeight      Float    @default(1)
  trustWeight       Float    @default(1)
  ctaWeight         Float    @default(1)
  seoWeight         Float    @default(1)
  conversionWeight  Float    @default(1)
  bookingWeight     Float    @default(1)
  socialProofWeight Float    @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("industry_scoring_rules")
}

model ServiceOpportunity {
  id                String        @id @default(cuid())
  leadId            String
  lead              Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  serviceId         String
  service           AgencyService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  score             Int
  estimatedMinValue Int
  estimatedMaxValue Int
  reason            String        @db.Text
  recommended       Boolean       @default(false)
  createdAt         DateTime      @default(now())

  @@unique([leadId, serviceId])
  @@index([recommended])
  @@index([score])
  @@map("service_opportunities")
}

model OutreachDraft {
  id          String              @id @default(cuid())
  leadId      String
  userId      String
  lead        Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        OutreachType
  subject     String?
  opener      String              @db.Text
  pitch       String              @db.Text
  cta         String              @db.Text
  fullMessage String              @db.Text
  status      OutreachDraftStatus @default(DRAFT)
  tone        String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([leadId])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("outreach_drafts")
}

model Competitor {
  id             String   @id @default(cuid())
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company        String
  website        String
  screenshotPath String?
  score          Int      @default(5)
  strengths      Json?
  weaknesses     Json?
  createdAt      DateTime @default(now())

  @@unique([leadId, website])
  @@index([leadId])
  @@map("competitors")
}

model LeadIssue {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  issueText String
  createdAt DateTime @default(now())

  @@map("lead_issues")
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  userId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@map("lead_notes")
}

model LeadStatusHistory {
  id        String     @id @default(cuid())
  leadId    String
  userId    String
  lead      Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  oldStatus LeadStatus?
  newStatus LeadStatus
  oldStage  PipelineStage?
  newStage  PipelineStage?
  createdAt DateTime   @default(now())

  @@index([leadId])
  @@map("lead_status_history")
}

model Import {
  id         String   @id @default(cuid())
  fileName   String
  importedBy String
  user       User     @relation(fields: [importedBy], references: [id], onDelete: Cascade)
  totalRows  Int
  createdAt  DateTime @default(now())

  @@map("imports")
}

model Screenshot {
  id           String         @id @default(cuid())
  leadId       String?
  scanResultId String?
  lead         Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  scanResult   ScanResult?    @relation(fields: [scanResultId], references: [id], onDelete: Cascade)
  imagePath    String
  type         ScreenshotType @default(DESKTOP)
  createdAt    DateTime      @default(now())

  @@map("screenshots")
}

model ScanJob {
  id          String        @id @default(cuid())
  keyword     String
  location    String
  maxResults  Int          @default(10)
  status      ScanJobStatus @default(PENDING)
  createdBy   String
  user        User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  progress    Int           @default(0)
  logs        Json?
  retryCount  Int           @default(0)
  startedAt   DateTime?
  failedAt    DateTime?
  scanDepth   ScanDepth     @default(QUICK)
  country     String?
  state       String?
  city        String?
  minReviews  Int?
  hasWebsiteOnly Boolean    @default(false)
  results     ScanResult[]
  createdAt   DateTime      @default(now())
  completedAt DateTime?

  @@index([status])
  @@map("scan_jobs")
}

model ScanResult {
  id                   String        @id @default(cuid())
  scanJobId            String
  scanJob              ScanJob       @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  company              String
  website              String?
  phone                String?
  address              String?
  industry             String?
  location             String?
  score                Int           @default(7)
  visualDesignScore    Int?
  mobileScore          Int?
  trustScore           Int?
  ctaScore             Int?
  seoScore             Int?
  opportunityScore     Int?
  estimatedProjectValue String?
  priority             LeadPriority  @default(COLD)
  websiteStatus        WebsiteStatus @default(UNKNOWN)
  statusCode           Int?
  accessIssue          String?
  accessIssueReason    String?       @db.Text
  lastCheckedAt        DateTime?
  loadTime             Int?
  sslValid             Boolean?
  redirectCount        Int?
  extractedHeadings    Json?
  extractedCTAs        Json?
  extractedForms       Json?
  extractedSocialLinks Json?
  extractedEmails      Json?
  extractedPhones      Json?
  contactPageUrl       String?
  rawExtractedData     Json?
  screenshotPath       String?
  mobileScreenshotPath String?
  issues               Json?
  recommendedFixes     Json?
  outreachEmail        String?       @db.Text
  imported             Boolean       @default(false)
  duplicate            Boolean       @default(false)
  screenshots          Screenshot[]
  createdAt            DateTime      @default(now())

  @@index([scanJobId])
  @@index([priority])
  @@index([websiteStatus])
  @@map("scan_results")
}

model ScanTemplate {
  id         String   @id @default(cuid())
  name       String
  keyword    String
  location   String
  maxResults Int      @default(10)
  filters    Json?
  createdBy  String
  user       User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  automationSchedules AutomationSchedule[]
  createdAt  DateTime @default(now())

  @@map("scan_templates")
}

model AutomationSchedule {
  id          String              @id @default(cuid())
  name        String
  templateId  String
  template    ScanTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  frequency   AutomationFrequency
  enabled     Boolean             @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdBy   String
  user        User                @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  notifications AutomationNotification[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([enabled])
  @@index([nextRunAt])
  @@map("automation_schedules")
}

model AutomationNotification {
  id          String                     @id @default(cuid())
  scheduleId  String?
  schedule    AutomationSchedule?        @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdBy   String
  user        User                       @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  type        AutomationNotificationType @default(INFO)
  title       String
  message     String                     @db.Text
  read        Boolean                    @default(false)
  createdAt   DateTime                   @default(now())

  @@index([createdBy])
  @@index([scheduleId])
  @@index([read])
  @@map("automation_notifications")
}
