generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum LeadPriority {
  HOT
  WARM
  COLD
}

enum LeadStatus {
  NOT_CONTACTED
  CONTACTED
  REPLIED
  CLOSED
  ARCHIVED
}

enum PipelineStage {
  NOT_CONTACTED
  DRAFTED
  SENT
  REPLIED
  BOUNCED
  MEETING
  PROPOSAL
  WON
  LOST
}

enum WebsiteStatus {
  WORKING
  CLOUDFLARE
  CAPTCHA
  FORBIDDEN
  NOT_FOUND
  SERVER_ERROR
  SSL_ERROR
  TIMEOUT
  REDIRECT_LOOP
  DOMAIN_PARKED
  WEBSITE_OFFLINE
  NO_WEBSITE
  BOT_PROTECTION
  UNKNOWN
}

enum ScanJobStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum ScanDepth {
  QUICK
  FULL
  DEEP
}

enum ScreenshotType {
  DESKTOP
  MOBILE
}

enum OutreachType {
  EMAIL
  LINKEDIN_DM
  COLD_CALL
  FOLLOW_UP_1
  FOLLOW_UP_2
}

enum OutreachDraftStatus {
  DRAFT
  SAVED
  COPIED
  SENT
  ARCHIVED
}

enum AutomationFrequency {
  DAILY
  WEEKLY
}

enum AutomationNotificationType {
  INFO
  SUCCESS
  ERROR
}

enum EmailProvider {
  GOOGLE
  MICROSOFT
}

enum EmailSendStatus {
  DRAFT
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum EmailSendMode {
  MANUAL_APPROVAL
  AUTO_SEND
}

enum EmailSendEventType {
  OUTBOUND
  FOLLOW_UP_1
  FOLLOW_UP_2
  REPLY
}

enum FollowUpStatus {
  NOT_STARTED
  SCHEDULED
  FOLLOW_UP_1_DUE
  FOLLOW_UP_1_SENT
  FOLLOW_UP_2_DUE
  FOLLOW_UP_2_SENT
  COMPLETED
  STOPPED
  FAILED
}

enum ReplyClassification {
  INTERESTED
  MAYBE_LATER
  NOT_INTERESTED
  ASKED_FOR_PRICE
  ASKED_FOR_MORE_INFO
  WRONG_CONTACT
  AUTO_REPLY
  OTHER
}

enum EmailBulkJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  senderName              String?
  senderTitle             String?
  senderEmail             String?
  companyName             String?
  signature               String?                  @db.Text
  profilePhoto            String?
  passwordHash            String
  role                    UserRole                 @default(ADMIN)
  notes                   LeadNote[]
  statusHistory           LeadStatusHistory[]
  imports                 Import[]
  scanJobs                ScanJob[]
  scanTemplates           ScanTemplate[]
  assignedLeads           Lead[]                   @relation("LeadOwner")
  outreachDrafts          OutreachDraft[]
  emailAccounts           EmailAccount[]
  emailSends              EmailSend[]
  auditReports            AuditReport[]
  emailBulkJobs           EmailBulkJob[]
  evidenceCorrections     EvidenceCorrection[]
  automationSchedules     AutomationSchedule[]
  automationNotifications AutomationNotification[]
  settingsUpdates         AppSetting[]             @relation("SettingUpdater")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@map("users")
}

model Lead {
  id                            String               @id @default(cuid())
  company                       String
  website                       String               @unique
  phone                         String?
  address                       String?
  industry                      String?
  industryId                    String?
  industryRef                   Industry?            @relation(fields: [industryId], references: [id], onDelete: SetNull)
  location                      String?
  screenshotPath                String?
  mobileScreenshotPath          String?
  score                         Int                  @default(7)
  visualDesignScore             Int?
  mobileScore                   Int?
  trustScore                    Int?
  ctaScore                      Int?
  seoScore                      Int?
  conversionScore               Int?
  speedScore                    Int?
  bookingScore                  Int?
  analyticsScore                Int?
  contactabilityScore           Int?
  opportunityScore              Int?
  estimatedMinValue             Int?
  estimatedMaxValue             Int?
  actualRevenue                 Int?
  profit                        Int?
  monthlyRetainer               Int?
  annualRetainer                Int?
  paymentStatus                 String?
  wonAt                         DateTime?
  emailStatus                   String?
  lastContactedAt               DateTime?
  lastEmailSentAt               DateTime?
  repliedAt                     DateTime?
  lastReplySnippet              String?              @db.Text
  lastReplyFrom                 String?
  lastReplyMessageId            String?
  replyClassification           ReplyClassification?
  replyClassificationConfidence Float?
  suggestedNextAction           String?
  needsAction                   Boolean              @default(false)
  needsActionReason             String?
  doNotContact                  Boolean              @default(false)
  doNotContactReason            String?
  doNotContactAt                DateTime?
  bouncedAt                     DateTime?
  bounceReason                  String?              @db.Text
  gmailMessageId                String?
  gmailThreadId                 String?
  followUpStatus                FollowUpStatus       @default(NOT_STARTED)
  followUpStep                  Int                  @default(0)
  nextFollowUpAt                DateTime?
  lastFollowUpSentAt            DateTime?
  followUpStoppedReason         String?
  estimatedProjectValue         String?
  priority                      LeadPriority         @default(COLD)
  outreachEmail                 String?              @db.Text
  status                        LeadStatus           @default(NOT_CONTACTED)
  pipelineStage                 PipelineStage        @default(NOT_CONTACTED)
  assignedToUserId              String?
  assignedTo                    User?                @relation("LeadOwner", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  reminderDate                  DateTime?
  websiteStatus                 WebsiteStatus        @default(UNKNOWN)
  statusCode                    Int?
  accessIssue                   String?
  accessIssueReason             String?              @db.Text
  lastCheckedAt                 DateTime?
  cms                           String?
  analyticsGa4                  Boolean              @default(false)
  analyticsGtm                  Boolean              @default(false)
  analyticsMetaPixel            Boolean              @default(false)
  bookingCalendly               Boolean              @default(false)
  bookingSimplyBook             Boolean              @default(false)
  bookingAcuity                 Boolean              @default(false)
  marketingMailchimp            Boolean              @default(false)
  marketingHubspot              Boolean              @default(false)
  marketingKlaviyo              Boolean              @default(false)
  chatIntercom                  Boolean              @default(false)
  chatTawk                      Boolean              @default(false)
  chatZendesk                   Boolean              @default(false)
  generalEmail                  String?
  ownerEmail                    String?
  linkedinCompany               String?
  instagram                     String?
  facebook                      String?
  whatsapp                      String?
  contactConfidence             Int?
  contactSource                 String?
  scanEvidence                  Json?
  recommendedFixes              Json?
  issues                        LeadIssue[]
  notes                         LeadNote[]
  statusHistory                 LeadStatusHistory[]
  screenshots                   Screenshot[]
  serviceOpportunities          ServiceOpportunity[]
  outreachDrafts                OutreachDraft[]
  emailSends                    EmailSend[]
  auditReports                  AuditReport[]
  competitors                   Competitor[]
  evidenceCorrections           EvidenceCorrection[]
  createdAt                     DateTime             @default(now())
  updatedAt                     DateTime             @updatedAt

  @@index([company])
  @@index([industry])
  @@index([industryId])
  @@index([location])
  @@index([status])
  @@index([pipelineStage])
  @@index([assignedToUserId])
  @@index([reminderDate])
  @@index([emailStatus])
  @@index([lastContactedAt])
  @@index([lastEmailSentAt])
  @@index([repliedAt])
  @@index([gmailThreadId])
  @@index([replyClassification])
  @@index([needsAction])
  @@index([doNotContact])
  @@index([bouncedAt])
  @@index([followUpStatus])
  @@index([nextFollowUpAt])
  @@index([priority])
  @@index([websiteStatus])
  @@index([cms])
  @@index([analyticsGa4])
  @@index([analyticsGtm])
  @@index([analyticsMetaPixel])
  @@index([bookingCalendly])
  @@index([bookingSimplyBook])
  @@index([bookingAcuity])
  @@map("leads")
}

model Industry {
  id                    String               @id @default(cuid())
  name                  String
  slug                  String               @unique
  description           String?              @db.Text
  defaultKeywords       String?              @db.Text
  auditCriteria         String?              @db.Text
  recommendedServiceIds Json?
  workspaceSections     Json?
  enabled               Boolean              @default(true)
  scoringRule           IndustryScoringRule?
  leads                 Lead[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([enabled])
  @@map("industries")
}

model AgencyService {
  id            String               @id @default(cuid())
  name          String
  slug          String               @unique
  description   String?              @db.Text
  baseMinValue  Int
  baseMaxValue  Int
  enabled       Boolean              @default(true)
  opportunities ServiceOpportunity[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([enabled])
  @@map("services")
}

model AppSetting {
  key       String   @id
  value     Json
  updatedBy String?
  user      User?    @relation("SettingUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model ConsultantKnowledgeModel {
  id                     String   @id @default(cuid())
  businessType           String
  normalizedBusinessType String
  industry               String
  normalizedIndustry     String
  country                String   @default("")
  market                 String   @default("")
  knowledgeJson          Json
  version                String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([normalizedBusinessType, normalizedIndustry, country, market, version])
  @@index([normalizedBusinessType])
  @@index([normalizedIndustry])
  @@index([version])
  @@map("consultant_knowledge_models")
}

model IndustryScoringRule {
  id                String   @id @default(cuid())
  industryId        String   @unique
  industry          Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)
  designWeight      Float    @default(1)
  mobileWeight      Float    @default(1)
  trustWeight       Float    @default(1)
  ctaWeight         Float    @default(1)
  seoWeight         Float    @default(1)
  conversionWeight  Float    @default(1)
  bookingWeight     Float    @default(1)
  socialProofWeight Float    @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("industry_scoring_rules")
}

model ServiceOpportunity {
  id                String        @id @default(cuid())
  leadId            String
  lead              Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  serviceId         String
  service           AgencyService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  score             Int
  estimatedMinValue Int
  estimatedMaxValue Int
  confidence        Int?
  reason            String        @db.Text
  recommended       Boolean       @default(false)
  createdAt         DateTime      @default(now())

  @@unique([leadId, serviceId])
  @@index([recommended])
  @@index([score])
  @@map("service_opportunities")
}

model OutreachDraft {
  id          String              @id @default(cuid())
  leadId      String
  userId      String
  lead        Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        OutreachType
  subject     String?
  opener      String              @db.Text
  pitch       String              @db.Text
  cta         String              @db.Text
  fullMessage String              @db.Text
  status      OutreachDraftStatus @default(DRAFT)
  tone        String?
  emailSends  EmailSend[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([leadId])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("outreach_drafts")
}

model EmailAccount {
  id                    String         @id @default(cuid())
  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider              EmailProvider
  email                 String
  accessTokenEncrypted  String         @db.Text
  refreshTokenEncrypted String         @db.Text
  expiresAt             DateTime?
  connectedAt           DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  sends                 EmailSend[]
  bulkJobs              EmailBulkJob[]

  @@unique([userId, provider, email])
  @@index([userId])
  @@map("email_accounts")
}

model EmailSend {
  id              String             @id @default(cuid())
  leadId          String
  lead            Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  outreachDraftId String?
  outreachDraft   OutreachDraft?     @relation(fields: [outreachDraftId], references: [id], onDelete: SetNull)
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAccountId  String?
  emailAccount    EmailAccount?      @relation(fields: [emailAccountId], references: [id], onDelete: SetNull)
  auditReportId   String?
  auditReport     AuditReport?       @relation(fields: [auditReportId], references: [id], onDelete: SetNull)
  toEmail         String
  subject         String
  body            String             @db.Text
  provider        String             @default("GMAIL")
  mode            EmailSendMode      @default(MANUAL_APPROVAL)
  status          EmailSendStatus    @default(PENDING)
  eventType       EmailSendEventType @default(OUTBOUND)
  sentAt          DateTime?
  receivedAt      DateTime?
  fromEmail       String?
  snippet         String?            @db.Text
  gmailMessageId  String?            @unique
  gmailThreadId   String?
  errorMessage    String?            @db.Text
  createdAt       DateTime           @default(now())

  @@index([leadId])
  @@index([userId])
  @@index([emailAccountId])
  @@index([auditReportId])
  @@index([status])
  @@index([eventType])
  @@index([gmailThreadId])
  @@index([receivedAt])
  @@map("email_sends")
}

model AuditReport {
  id               String      @id @default(cuid())
  leadId           String
  lead             Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           String      @default("not_started")
  pdfUrl           String?
  pdfPath          String?
  reportData       Json
  selectedServices Json?
  screenshots      Json?
  issues           Json?
  recommendations  Json?
  qualityGate      Json?
  debugData        Json?
  summary          String?     @db.Text
  opportunityScore Int?
  confidenceScore  Int?
  error            String?     @db.Text
  generatedAt      DateTime?
  approvedAt       DateTime?
  attachedAt       DateTime?
  sentAt           DateTime?
  emailSends       EmailSend[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([leadId])
  @@index([userId])
  @@index([status])
  @@map("audit_reports")
}

model EmailBulkJob {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAccountId String?
  emailAccount   EmailAccount?      @relation(fields: [emailAccountId], references: [id], onDelete: SetNull)
  mode           EmailSendMode
  totalLeads     Int
  sentCount      Int                @default(0)
  failedCount    Int                @default(0)
  skippedCount   Int                @default(0)
  currentLeadId  String?
  status         EmailBulkJobStatus @default(PENDING)
  logs           Json?
  createdAt      DateTime           @default(now())
  completedAt    DateTime?

  @@index([userId])
  @@index([status])
  @@map("email_bulk_jobs")
}

model Competitor {
  id             String   @id @default(cuid())
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company        String
  website        String
  screenshotPath String?
  score          Int      @default(5)
  strengths      Json?
  weaknesses     Json?
  createdAt      DateTime @default(now())

  @@unique([leadId, website])
  @@index([leadId])
  @@map("competitors")
}

model EvidenceCorrection {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  signalKey   String
  value       String
  notes       String?  @db.Text
  correctedBy String
  user        User     @relation(fields: [correctedBy], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([leadId, signalKey])
  @@index([leadId])
  @@index([correctedBy])
  @@map("evidence_corrections")
}

model LeadIssue {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  issueText String
  createdAt DateTime @default(now())

  @@map("lead_issues")
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  userId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@map("lead_notes")
}

model LeadStatusHistory {
  id        String         @id @default(cuid())
  leadId    String
  userId    String
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  oldStatus LeadStatus?
  newStatus LeadStatus
  oldStage  PipelineStage?
  newStage  PipelineStage?
  createdAt DateTime       @default(now())

  @@index([leadId])
  @@map("lead_status_history")
}

model Import {
  id            String   @id @default(cuid())
  fileName      String
  importedBy    String
  user          User     @relation(fields: [importedBy], references: [id], onDelete: Cascade)
  totalRows     Int
  importedRows  Int      @default(0)
  duplicateRows Int      @default(0)
  failedRows    Int      @default(0)
  createdAt     DateTime @default(now())

  @@map("imports")
}

model Screenshot {
  id           String         @id @default(cuid())
  leadId       String?
  scanResultId String?
  lead         Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  scanResult   ScanResult?    @relation(fields: [scanResultId], references: [id], onDelete: Cascade)
  imagePath    String
  type         ScreenshotType @default(DESKTOP)
  createdAt    DateTime       @default(now())

  @@map("screenshots")
}

model ScanJob {
  id              String        @id @default(cuid())
  keyword         String
  location        String
  maxResults      Int           @default(10)
  scanMode        String        @default("GOOGLE_PLACES")
  directUrls      Json?
  status          ScanJobStatus @default(PENDING)
  createdBy       String
  user            User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  progress        Int           @default(0)
  currentStage    String?
  progressPercent Int           @default(0)
  totalItems      Int           @default(0)
  completedItems  Int           @default(0)
  failedItems     Int           @default(0)
  currentUrl      String?
  logs            Json?
  retryCount      Int           @default(0)
  startedAt       DateTime?
  failedAt        DateTime?
  scanDepth       ScanDepth     @default(QUICK)
  country         String?
  state           String?
  city            String?
  minReviews      Int?
  hasWebsiteOnly  Boolean       @default(false)
  results         ScanResult[]
  createdAt       DateTime      @default(now())
  completedAt     DateTime?

  @@index([status])
  @@index([scanMode])
  @@map("scan_jobs")
}

model ScanResult {
  id                    String        @id @default(cuid())
  scanJobId             String
  scanJob               ScanJob       @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  company               String
  website               String?
  phone                 String?
  address               String?
  industry              String?
  location              String?
  score                 Int           @default(7)
  visualDesignScore     Int?
  mobileScore           Int?
  trustScore            Int?
  ctaScore              Int?
  seoScore              Int?
  conversionScore       Int?
  speedScore            Int?
  bookingScore          Int?
  analyticsScore        Int?
  contactabilityScore   Int?
  opportunityScore      Int?
  estimatedProjectValue String?
  priority              LeadPriority  @default(COLD)
  websiteStatus         WebsiteStatus @default(UNKNOWN)
  statusCode            Int?
  accessIssue           String?
  accessIssueReason     String?       @db.Text
  lastCheckedAt         DateTime?
  loadTime              Int?
  sslValid              Boolean?
  redirectCount         Int?
  extractedHeadings     Json?
  extractedCTAs         Json?
  extractedForms        Json?
  extractedSocialLinks  Json?
  extractedEmails       Json?
  extractedPhones       Json?
  contactPageUrl        String?
  rawExtractedData      Json?
  cms                   String?
  analyticsGa4          Boolean       @default(false)
  analyticsGtm          Boolean       @default(false)
  analyticsMetaPixel    Boolean       @default(false)
  bookingCalendly       Boolean       @default(false)
  bookingSimplyBook     Boolean       @default(false)
  bookingAcuity         Boolean       @default(false)
  marketingMailchimp    Boolean       @default(false)
  marketingHubspot      Boolean       @default(false)
  marketingKlaviyo      Boolean       @default(false)
  chatIntercom          Boolean       @default(false)
  chatTawk              Boolean       @default(false)
  chatZendesk           Boolean       @default(false)
  generalEmail          String?
  ownerEmail            String?
  linkedinCompany       String?
  instagram             String?
  facebook              String?
  whatsapp              String?
  contactConfidence     Int?
  contactSource         String?
  scanEvidence          Json?
  screenshotPath        String?
  mobileScreenshotPath  String?
  issues                Json?
  recommendedFixes      Json?
  outreachEmail         String?       @db.Text
  imported              Boolean       @default(false)
  duplicate             Boolean       @default(false)
  screenshots           Screenshot[]
  createdAt             DateTime      @default(now())

  @@index([scanJobId])
  @@index([priority])
  @@index([websiteStatus])
  @@map("scan_results")
}

model ScanTemplate {
  id                  String               @id @default(cuid())
  name                String
  keyword             String
  location            String
  maxResults          Int                  @default(10)
  filters             Json?
  createdBy           String
  user                User                 @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  automationSchedules AutomationSchedule[]
  createdAt           DateTime             @default(now())

  @@map("scan_templates")
}

model AutomationSchedule {
  id            String                   @id @default(cuid())
  name          String
  templateId    String
  template      ScanTemplate             @relation(fields: [templateId], references: [id], onDelete: Cascade)
  frequency     AutomationFrequency
  enabled       Boolean                  @default(true)
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  createdBy     String
  user          User                     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  notifications AutomationNotification[]
  runs          AutomationRun[]
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([enabled])
  @@index([nextRunAt])
  @@map("automation_schedules")
}

model AutomationRun {
  id              String             @id @default(cuid())
  scheduleId      String
  schedule        AutomationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scanJobId       String?
  currentStage    String?
  progressPercent Int                @default(0)
  totalItems      Int                @default(0)
  completedItems  Int                @default(0)
  failedItems     Int                @default(0)
  currentUrl      String?
  logs            Json?
  startedAt       DateTime           @default(now())
  completedAt     DateTime?
  createdAt       DateTime           @default(now())

  @@index([scheduleId])
  @@index([scanJobId])
  @@map("automation_runs")
}

model AutomationNotification {
  id         String                     @id @default(cuid())
  scheduleId String?
  schedule   AutomationSchedule?        @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdBy  String
  user       User                       @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  type       AutomationNotificationType @default(INFO)
  title      String
  message    String                     @db.Text
  read       Boolean                    @default(false)
  createdAt  DateTime                   @default(now())

  @@index([createdBy])
  @@index([scheduleId])
  @@index([read])
  @@map("automation_notifications")
}
